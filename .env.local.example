# ─── Supabase service role (server-only — never expose to browser) ────────────
# Required for cron jobs that read all users (email digests, overdue checks).
# Find this in: Supabase Dashboard > Project Settings > API > service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Email notifications (Resend) ─────────────────────────────────────────────
# Sign up at https://resend.com, create an API key, and verify your sending domain.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=MyStackd <notifications@yourdomain.com>

# ─── Cron job security ────────────────────────────────────────────────────────
# Any random secret string. Set the same value in Vercel > Settings > Environment Variables.
# Vercel Cron will send this as: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=your-random-secret-here

# ─── App URL (used in email links) ────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
